import os
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_squared_error
from sklearn.linear_model import LassoCV, Lasso
from sklearn.model_selection import KFold
##Part 1

#paths to the data
data_directory= '/content/drive/MyDrive/AMATH_482'#put the directory of your data here
train_path=os.path.join(data_directory,'wine_training.csv')
test_path=os.path.join(data_directory,'wine_test.csv')

#loading the data
d_train = np.loadtxt(train_path, dtype=float, delimiter=',')
d_test = np.loadtxt(test_path, dtype=float, delimiter=',')

X_train = d_train[:, 0:11]
X_test = d_test[:, 0:11]

Y_train = d_train[:,11]
Y_test = d_test[:,11]

print(X_train.shape)
##normalizing and centering the data
scaler_X = StandardScaler()
scaler_Y = StandardScaler()


X_train_scaled = scaler_X.fit_transform(X_train)
Y_train_scaled = scaler_Y.fit_transform(Y_train.reshape(-1, 1))

X_test_scaled = scaler_X.transform(X_test)
Y_test_scaled = scaler_Y.transform(Y_test.reshape(-1, 1))

## fitting a first order linear model
ols = LinearRegression(fit_intercept=True)
ols.fit(X_train_scaled, Y_train_scaled)


Y_pred_test_scaled = ols.predict(X_test_scaled)

mse = mean_squared_error(Y_test_scaled, Y_pred_test_scaled)

print("The test MSE: ", mse)


coefs = ols.coef_.flatten()

abs_coefs = np.abs(coefs)
top5_idx = np.argsort(abs_coefs)[-5:]

print(top5_idx)
print(abs_coefs[top5_idx])


##Part 2

Xtr_squared = np.hstack((X_train_scaled, X_train_scaled**2))
Xte_squared = np.hstack((X_test_scaled, X_test_scaled**2))

ols_squared = LinearRegression(fit_intercept=True)
ols_squared.fit(Xtr_squared, Y_train_scaled)

Y_pred_test_squared_scaled = ols_squared.predict(Xte_squared)

mse_squared = mean_squared_error(Y_test_scaled, Y_pred_test_squared_scaled)

print("The test MSE with squared features: ", mse_squared)

##Part 3

S = [1, 4, 6, 9, 10]

def interaction_block(X, S):
    cols = []
    for a in range(len(S)):
        for b in range(a + 1, len(S)):
            i, j = S[a], S[b]
            cols.append((X[:, i] * X[:, j]).reshape(-1, 1))
    return np.hstack(cols)


Xtr_int = interaction_block(X_train_scaled, S)
Xte_int = interaction_block(X_test_scaled, S)

Xtr_design = np.hstack([X_train_scaled, Xtr_int])
Xte_design = np.hstack([X_test_scaled,  Xte_int])


ols_int = LinearRegression(fit_intercept=True)
ols_int.fit(Xtr_design, Y_train_scaled)

y_pred_test_s = ols_int.predict(Xte_design)
test_mse = mean_squared_error(Y_test_scaled, y_pred_test_s)

print("The test MSE with interactions: ", test_mse)
cv = KFold(n_splits=7, shuffle=True, random_state=42)

lasso_cv = LassoCV(cv=cv, max_iter=10000)
lasso_cv.fit(Xtr_design, Y_train_scaled.ravel())

lambda_selected = lasso_cv.alpha_
print("Selected alpha from CV:", lambda_selected)

lasso_final = Lasso(alpha=lambda_selected, max_iter=10000)
lasso_final.fit(Xtr_design, Y_train_scaled.ravel())

Y_pred_lasso_test = lasso_final.predict(Xte_design)

lasso_test_mse = mean_squared_error(Y_test_scaled, Y_pred_lasso_test)
print("Test MSE (Lasso interaction model):", lasso_test_mse)

lasso_coefs = lasso_final.coef_
nonzero_idx = np.where(lasso_coefs != 0)[0]

print("Indices of nonzero coefficients:", nonzero_idx)
print("Values of nonzero coefficients:", lasso_coefs[nonzero_idx])
