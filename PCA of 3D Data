import os
from sklearn.metrics import accuracy_score

plt.style.use('seaborn-v0_8-poster')

debug = True
#filename and folder to plot
fname= "walking_1"
folder =  '/content/drive/MyDrive/train' #put path to the training data here


location_name=os.path.join(folder,fname+".npy")
vals = np.load(location_name)

##Part 1
files = sorted([f for f in os.listdir(folder) if f.endswith('.npy')])

blocks = []

for f in files:
    vals = np.load(os.path.join(folder, f))

    xyz = vals.reshape(38, 3, -1)

    block = xyz.reshape(114, xyz.shape[2])

    blocks.append(block)


X_train = np.concatenate(blocks, axis=1)
mu = np.sum(X_train, axis=1) / X_train.shape[1]
mu = mu.reshape(114, 1)

if debug:
  print("Final shape:", X_train.shape)
  print(X_train.shape[1])

Z = X_train - mu

U, S, V = np.linalg.svd(Z, full_matrices=False)

A = (S[:, None]) * V


energy = S**2
cmltv_energy = np.cumsum(energy) / np.sum(energy)

targets = [0.70, 0.80, 0.90, 0.95]
r_needed = {t: int(np.searchsorted(cmltv_energy, t) + 1) for t in targets}
print("Modes needed:", r_needed)

plt.figure()
plt.plot(np.arange(1, len(cmltv_energy)+1), cmltv_energy)
for t in targets:
    plt.axhline(t, linestyle='--')
    plt.axvline(r_needed[t], linestyle='--')
plt.xlabel("Number of modes r")
plt.ylabel("Cumulative energy")
plt.title("Cumulative PCA energy")
plt.show()

##Part 2

colors = {
    "walking":  "tab:blue",
    "running":  "tab:orange",
    "jumping":  "tab:green",
}
def movement_label(filename: str):
    name = filename.lower()
    if "walking" in name:
        return "walking"
    if "running" in name:
        return "running"
    if "jumping" in name:
        return "jumping"
    return None

lengths = []
for f in files:
    vals_f = np.load(os.path.join(folder, f))
    T = vals_f.reshape(38, 3, -1).shape[2]
    lengths.append(T)



starts = np.cumsum([0] + lengths[:-1])
ends   = np.cumsum(lengths)


plt.figure(figsize=(9, 7))
legend_added = set()

for i, f in enumerate(files):
    label = movement_label(f)

    sl = slice(starts[i], ends[i])
    traj2 = A[:2, sl]


    show_label = label if label not in legend_added else None

    plt.plot(
        traj2[0, :],
        traj2[1, :],
        color=colors[label],
        alpha=0.85,
        linewidth=2,
        label=show_label
    )

    legend_added.add(label)

plt.xlabel("PC1 coefficient")
plt.ylabel("PC2 coefficient")
plt.title("Trajectories in truncated PCA space (2D) grouped by movement")
plt.legend()
plt.tight_layout()
plt.show()


fig = plt.figure(figsize=(9, 7))
ax = fig.add_subplot(111, projection="3d")
legend_added = set()

for i, f in enumerate(files):
    label = movement_label(f)
    if label is None:
        continue

    sl = slice(starts[i], ends[i])
    traj3 = A[:3, sl]

    show_label = label if label not in legend_added else None

    ax.plot(
        traj3[0, :],
        traj3[1, :],
        traj3[2, :],
        color=colors[label],
        alpha=0.85,
        linewidth=2,
        label=show_label
    )

    legend_added.add(label)

ax.set_xlabel("PC1 coefficient")
ax.set_ylabel("PC2 coefficient")
ax.set_zlabel("PC3 coefficient")
ax.set_title("Trajectories in truncated PCA space (3D) grouped by movement")
ax.legend()
plt.tight_layout()
plt.show()

##Part 3

label_to_int = {"walking": 0, "jumping": 1, "running": 2}
int_to_label = {v: k for k, v in label_to_int.items()}

y_true = np.empty(X_train.shape[1], dtype=int)

for i, f in enumerate(files):
    lbl = movement_label(f)
    sl = slice(starts[i], ends[i])
    y_true[sl] = label_to_int[lbl]



k_values = range(2, 21)

centroids_by_k = {}

for k in k_values:
    A_k = A[:k, :]

    centroids = {}
    for name, lab in label_to_int.items():
        idx = (y_true == lab)
        centroids[lab] = np.mean(A_k[:, idx], axis=1)

    centroids_by_k[k] = centroids



# ##Part 4

train_acc = {}
y_pred_by_k = {}

for k in k_values:
    A_k = A[:k, :]
    centroids = centroids_by_k[k]

    y_pred = np.empty_like(y_true)


    for j in range(A_k.shape[1]):
        x = A_k[:, j]


        dists = {lab: np.linalg.norm(x - centroids[lab]) for lab in centroids}


        y_pred[j] = min(dists, key=dists.get)

    y_pred_by_k[k] = y_pred


    acc = accuracy_score(y_true, y_pred)
    train_acc[k] = acc
    print(f"k = {k:3d} | train accuracy = {acc:.4f}")


plt.figure(figsize=(7, 5))
plt.plot(list(train_acc.keys()), list(train_acc.values()), marker="o")
plt.xlabel("k (number of PCA modes)")
plt.ylabel("Training accuracy")
plt.title("Nearest-centroid classifier accuracy vs k (train)")
plt.grid(True)
plt.show()


best_k = max(train_acc, key=train_acc.get)
print("Best k (train):", best_k, "accuracy:", train_acc[best_k])

# ##Part 5

test_folder = "/content/drive/MyDrive/test"

test_files = sorted([f for f in os.listdir(test_folder) if f.endswith(".npy")])

test_blocks = []
test_lengths = []

for f in test_files:
    vals_f = np.load(os.path.join(test_folder, f))
    xyz_f = vals_f.reshape(38, 3, -1)
    block_f = xyz_f.reshape(114, xyz_f.shape[2])
    test_blocks.append(block_f)
    test_lengths.append(xyz_f.shape[2])

X_train_test = np.concatenate(test_blocks, axis=1)

test_starts = np.cumsum([0] + test_lengths[:-1])
test_ends   = np.cumsum(test_lengths)



y_test_true = np.empty(X_train_test.shape[1], dtype=int)

for i, f in enumerate(test_files):
    lbl = movement_label(f)
    sl = slice(test_starts[i], test_ends[i])
    y_test_true[sl] = label_to_int[lbl]


Z_test = X_train_test - mu


def project_to_k(U, Z, k):
    U_k = U[:, :k]
    return U_k.T @ Z

def predict_nearest_centroid(A_k, centroids_dict):
    labs = sorted(centroids_dict.keys())
    C = np.stack([centroids_dict[lab] for lab in labs], axis=1)


    X2 = np.sum(A_k**2, axis=0, keepdims=True)
    C2 = np.sum(C**2, axis=0, keepdims=True)
    d2 = X2.T + C2 - 2 * (A_k.T @ C)

    idx = np.argmin(d2, axis=1)
    return np.array([labs[i] for i in idx], dtype=int)


test_acc = {}
y_test_pred_by_k = {}

for k in k_values:

    A_test_k = project_to_k(U, Z_test, k)
    centroids_train_k = centroids_by_k[k]
    y_test_pred = predict_nearest_centroid(A_test_k, centroids_train_k)
    y_test_pred_by_k[k] = y_test_pred

    acc = accuracy_score(y_test_true, y_test_pred)
    test_acc[k] = acc
    print(f"[TEST] k = {k:3d} | test accuracy = {acc:.4f}")


plt.figure(figsize=(7, 5))
plt.plot(list(train_acc.keys()), list(train_acc.values()), marker="o", label="train")
plt.plot(list(test_acc.keys()), list(test_acc.values()), marker="o", label="test")
plt.xlabel("k (number of PCA modes)")
plt.ylabel("Accuracy")
plt.title("Nearest-centroid accuracy vs k (train vs test)")
plt.legend()
plt.grid(True)
plt.show()

best_k_train = max(train_acc, key=train_acc.get)
best_k_test  = max(test_acc, key=test_acc.get)
print("Best k (train):", best_k_train, "acc:", train_acc[best_k_train])
print("Best k (test) :", best_k_test,  "acc:", test_acc[best_k_test])


